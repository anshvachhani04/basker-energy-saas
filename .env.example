# Basker Energy SaaS — Environment Variables
# Copy this file to .env and fill in your values

# API Security
SECRET_KEY=change-me-in-production

# Database
POSTGRES_PASSWORD=change-me
POSTGRES_USER=basker
POSTGRES_DB=basker_energy

# InfluxDB
INFLUXDB_TOKEN=change-me
INFLUXDB_ORG=basker-energy
INFLUXDB_BUCKET=solar-data

# Grafana
GRAFANA_PASSWORD=change-me

# Optional: external weather API
WEATHER_API_KEY=
